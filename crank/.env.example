# solcoach crank — daily quest generator + resolver
# both task_generator.py and task_resolver.py read this file in dev.
# in production, railway service vars take over.

# ── solana ──
ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
PROGRAM_ID=FoTaz3ejexSZgd9byVc1FpgqqqunBno7rx7ahfRMZMkU

# ── coach signing wallet — pick ONE ──
# inline JSON array of 64 bytes (railway-friendly):
CRANK_KEYPAIR_JSON=
# or filesystem path (local dev):
CRANK_KEYPAIR_PATH=./crank-keypair.json

# ── claude (task generation) ──
ANTHROPIC_API_KEY=

# ── helius (rpc + onchain queries) ──
HELIUS_API_KEY=
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ── schedule ──
TASK_GENERATION_CRON=0 8 * * *
YIELD_UPDATE_INTERVAL_MINUTES=30
