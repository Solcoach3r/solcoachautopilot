# SolCoach Autopilot — Environment Variables 🗺️
# copy this to .env and fill in your keys. nothing here is committed!

# ─── Anchor (smart contract side) ──────────────────────────
# devnet only please — we don't ship to mainnet
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
PROGRAM_ID=

# ─── RPC ───────────────────────────────────────────────────
# grab a free key at https://dev.helius.xyz — beats public devnet rpc
HELIUS_API_KEY=

# ─── AI (so the coach can actually coach) ──────────────────
# Claude key for daily quest generation + support chat
# get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Frontend ──────────────────────────────────────────────
VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
VITE_PROGRAM_ID=

# ─── Crank (the bit that runs in the background) ───────────
# this keypair signs daily quest mints + verification txs
CRANK_KEYPAIR_PATH=./crank-keypair.json
# cron expression — default is every day at 8am UTC
TASK_GENERATION_CRON=0 8 * * *
# how often to refresh the yield-aggregator cache (minutes)
YIELD_UPDATE_INTERVAL_MINUTES=30
